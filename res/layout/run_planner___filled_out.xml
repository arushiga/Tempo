        <View
            android:id="@+id/group_20"
        android:layout_width="365dp"
        android:layout_height="323dp" />

        <!-- TEXT: Upcoming Week (March 9-15) Easy Runs: 1 Tempo Runs: 1 Races Planned: 0 Long Runs Planned: 0 Relative Load (vs previous week): +43 Training Intensity (vs previous week): +15 -->
